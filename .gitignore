# Obsidian
.obsidian/workspace*
.obsidian/cache
.trash/

# Secrets
.env
.env.local
*.key

# Python
__pycache__/
*.pyc
.venv/
venv/

# macOS
.DS_Store

# Scratch — local-only working memory
_system/agent/memory/scratch/*
!_system/agent/memory/scratch/.gitkeep

# Logs — local-only audit trail
logs/*
!logs/.gitkeep
